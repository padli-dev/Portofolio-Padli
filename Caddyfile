{
	frankenphp
	auto_https off
}

:8000 {
	root * /app/public

	# Serve static files directly; fall back to index.php for everything else
	try_files {path} {path}/ /index.php?{query}

	# Pass PHP requests to FrankenPHP
	php_server

	# Cache static assets
	@static {
		file
		path *.css *.js *.ico *.png *.jpg *.jpeg *.gif *.svg *.woff *.woff2 *.ttf *.eot *.webp
	}
	header @static Cache-Control "public, max-age=31536000, immutable"

	# Security headers
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	encode gzip
}
